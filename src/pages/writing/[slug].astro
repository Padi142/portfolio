---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { getAllWriting, getWritingArticle } from "@/lib/writing";

export async function getStaticPaths() {
  const articles = await getAllWriting();
  return articles.map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = await getWritingArticle(slug!);

if (!article) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const { color } = article;
const pageTitle = `${article.title} | Portfolio`;
const pageDescription = article.description;
const shellStyle = [
  `--accent: ${color.accent}`,
  `--accent-bright: ${color.accentBright}`,
  `--accent-glow: ${color.glow}`,
  `--project-accent: ${color.accent}`,
  `--project-accent-bright: ${color.accentBright}`,
  `--project-hint: ${color.hint}`,
  `--project-glow: ${color.glow}`,
].join("; ");
---

<BaseLayout title={pageTitle} description={pageDescription} auroraStops={color.auroraStops}>
  <main
    class="relative z-[2] mx-auto w-[min(760px,calc(100%-40px))] pb-12 max-[560px]:w-[min(calc(100%-28px),760px)]"
    style={shellStyle}
  >
    <SiteHeader />

    <div
      class="mt-2 rounded-[20px] border border-[var(--border)] bg-[rgba(6,6,11,0.82)] p-8 backdrop-blur-[22px] shadow-[0_24px_64px_rgba(0,0,0,0.28),inset_0_1px_0_rgba(255,255,255,0.05)] max-[560px]:px-[18px] max-[560px]:py-6"
    >
      <article>
        <a
          class="inline-flex items-center text-[0.92rem] font-bold text-[var(--text-muted)] no-underline transition-colors hover:text-[var(--text)]"
          href="/writing"
        >
          ← All writing
        </a>

        <header class="mb-10 mt-5 border-b border-[var(--border)] pb-7">
          <div class="mb-4 flex flex-wrap items-center gap-3">
            {
              article.category && (
                <p class="m-0 flex items-center gap-[9px] font-mono text-[0.72rem] font-medium lowercase tracking-[0.02em] text-[var(--text-muted)] before:size-[7px] before:shrink-0 before:rounded-sm before:bg-[var(--project-accent)] before:opacity-72 before:content-['']">
                  {article.category}
                </p>
              )
            }
            {
              article.date && (
                <time
                  class="font-mono text-[0.72rem] text-[var(--text-muted)]"
                  datetime={article.date}
                >
                  {article.date}
                </time>
              )
            }
          </div>
          <h1 class="mb-[18px] font-display text-[clamp(2.2rem,6vw,3.4rem)] font-extrabold leading-[1.02] tracking-[-0.03em] text-[var(--text)]">
            {article.title}
          </h1>
          <p class="mb-7 max-w-[62ch] text-[clamp(1.05rem,2vw,1.2rem)] leading-[1.65] text-[var(--text-muted)]">
            {article.description}
          </p>

          {
            article.link && (
              <a
                class="btn-project-primary inline-flex min-h-[42px] items-center justify-center rounded-full border border-transparent px-[18px] text-[0.88rem] font-bold text-white no-underline transition-[background,transform] duration-200 hover:-translate-y-px"
                href={article.link}
                target="_blank"
                rel="noreferrer"
              >
                Read elsewhere
              </a>
            )
          }
        </header>

        <div class="prose-portfolio prose-writing" set:html={article.html} />
      </article>
    </div>

    <nav class="border-t border-[var(--border)] px-0 py-6 pb-3" aria-label="Writing navigation">
      <a
        class="inline-flex items-center text-[0.92rem] font-bold text-[var(--text-muted)] no-underline transition-colors hover:text-[var(--text)]"
        href="/writing"
      >
        ← All writing
      </a>
    </nav>
  </main>
</BaseLayout>
